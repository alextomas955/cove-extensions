{
  "name": "whisparr-sync-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "WhisparrSync settings page — the Cove Whisparr Sync extension's connection/setup frontend (Vite library bundle → index.mjs).",
  "license": "AGPL-3.0",
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "check-classes": "node scripts/check-classes.cjs",
    "check-connection-result": "node scripts/check-connection-result.mjs",
    "test": "node scripts/check-connection-result.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "npm run typecheck && npm run lint && npm run format:check && npm run check-classes && npm run test && npm run build"
  },
  "dependencies": {
    "@cove/extension-sdk": "file:vendor/cove-extension-sdk-0.1.0.tgz"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "lucide-react": "0.513.0",
    "prettier": "3.9.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vite": "8.1.3"
  },
  "volta": {
    "node": "24.11.0"
  }
}
