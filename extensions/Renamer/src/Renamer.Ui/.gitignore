node_modules/
# Ignore build output, EXCEPT the committed bundles: dist/index.mjs and dist/index.css are
# committed and shipped in the release package. CI rebuilds them from source and fails if a
# committed file is stale (the stale-bundle gate), so the tracked bundles are kept in sync with
# source. Exclude dir contents (not the dir itself) so the negations below can re-include them.
dist/*
!dist/index.mjs
!dist/index.css
