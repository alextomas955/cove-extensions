{
  "name": "renamer-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "RenameSettingsPanel — the Cove Renamer extension's settings + live-preview frontend (Vite library bundle → index.mjs).",
  "license": "AGPL-3.0",
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "check-classes": "node scripts/check-classes.cjs",
    "check-primitives-logic": "node scripts/check-primitives-logic.mjs",
    "check-entity-picker-logic": "node scripts/check-entity-picker-logic.mjs",
    "check-dry-run-logic": "node scripts/check-dry-run-logic.mjs",
    "check-template-validation": "node scripts/check-template-validation.mjs",
    "test": "node scripts/check-options-roundtrip.mjs && node scripts/check-primitives-logic.mjs && node scripts/check-entity-picker-logic.mjs && node scripts/check-studio-map.mjs && node scripts/check-dry-run-logic.mjs && node scripts/check-template-validation.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "npm run typecheck && npm run lint && npm run format:check && npm run check-classes && npm run test"
  },
  "dependencies": {
    "@cove/extension-sdk": "file:vendor/cove-extension-sdk-0.1.0.tgz"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "22.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "lucide-react": "0.513.0",
    "prettier": "3.9.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "5.8.3",
    "typescript-eslint": "8.62.1",
    "vite": "6.4.3"
  },
  "volta": {
    "node": "24.11.0"
  }
}
