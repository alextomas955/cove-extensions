# EditorConfig — root. https://aka.ms/editorconfigdocs
root = true

# ---------- All files ----------
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{json,jsonc,yml,yaml,md,cjs,mjs,ts,tsx,js,jsx}]
indent_size = 2

[*.{csproj,props,targets,slnx}]
indent_size = 2

# ---------- C# ----------
[*.cs]
indent_size = 4
# File-scoped namespaces, modern C# idioms
csharp_style_namespace_declarations = file_scoped:warning
csharp_using_directive_placement = outside_namespace:warning
csharp_prefer_braces = true:warning
csharp_style_var_for_built_in_types = false:silent
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_expression_bodied_methods = when_on_single_line:silent
csharp_prefer_simple_using_statement = true:suggestion
csharp_style_prefer_pattern_matching = true:warning
csharp_style_throw_expression = true:suggestion

# 'this.' qualification not required
dotnet_style_qualification_for_field = false:warning
dotnet_style_qualification_for_property = false:warning
dotnet_style_qualification_for_method = false:warning

# Language keywords over BCL type names (int vs Int32)
dotnet_style_predefined_type_for_locals_parameters_members = true:warning
dotnet_style_predefined_type_for_member_access = true:warning

# using ordering: System.* first, then alphabetical, no blank groups
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false
# IDE0005: remove unnecessary usings (escalate so CI/build catches dead usings)
dotnet_diagnostic.IDE0005.severity = warning

# Accessibility modifiers required
dotnet_style_require_accessibility_modifiers = for_non_interface_members:warning

# Naming: PascalCase types/members, _camelCase private fields, I-prefixed interfaces
dotnet_naming_rule.interfaces_pascal.symbols = interface_symbols
dotnet_naming_rule.interfaces_pascal.style = ipascal_style
dotnet_naming_rule.interfaces_pascal.severity = warning
dotnet_naming_symbols.interface_symbols.applicable_kinds = interface
dotnet_naming_style.ipascal_style.capitalization = pascal_case
dotnet_naming_style.ipascal_style.required_prefix = I

# const and static-readonly fields are PascalCase by C# convention (NOT _camelCase). These rules are
# listed FIRST so they win over the underscore rule below for those modifiers; without them, `dotnet
# format` flags idiomatic `private const string RouteBase` / `static readonly JsonSerializerOptions`
# as IDE1006 even though the build analyzers (EnforceCodeStyleInBuild) correctly exempt them.
# (required_modifiers is AND, so const and static-readonly need separate symbol sets.)
dotnet_naming_rule.const_fields_pascal.symbols = const_field_symbols
dotnet_naming_rule.const_fields_pascal.style = cpascal_style
dotnet_naming_rule.const_fields_pascal.severity = warning
dotnet_naming_symbols.const_field_symbols.applicable_kinds = field
dotnet_naming_symbols.const_field_symbols.required_modifiers = const

dotnet_naming_rule.static_readonly_fields_pascal.symbols = static_readonly_field_symbols
dotnet_naming_rule.static_readonly_fields_pascal.style = cpascal_style
dotnet_naming_rule.static_readonly_fields_pascal.severity = warning
dotnet_naming_symbols.static_readonly_field_symbols.applicable_kinds = field
dotnet_naming_symbols.static_readonly_field_symbols.required_modifiers = static,readonly

dotnet_naming_style.cpascal_style.capitalization = pascal_case

# ordinary private instance fields are _camelCase.
dotnet_naming_rule.private_fields_underscore.symbols = private_field_symbols
dotnet_naming_rule.private_fields_underscore.style = underscore_camel_style
dotnet_naming_rule.private_fields_underscore.severity = warning
dotnet_naming_symbols.private_field_symbols.applicable_kinds = field
dotnet_naming_symbols.private_field_symbols.applicable_accessibilities = private
dotnet_naming_style.underscore_camel_style.capitalization = camel_case
dotnet_naming_style.underscore_camel_style.required_prefix = _

# ---------- Analyzer category tuning (strict-but-not-pedantic) ----------
[*.cs]
# CA1062 (validate public args) is noisy for an internal-ish extension; keep as suggestion.
dotnet_diagnostic.CA1062.severity = suggestion
# CA1031 (do not catch general Exception) — the disk-mover/undo paths intentionally do; suggestion.
dotnet_diagnostic.CA1031.severity = suggestion
# CA2007 (ConfigureAwait) — not needed in a library hosted by ASP.NET; suppress to avoid churn.
dotnet_diagnostic.CA2007.severity = none

# DiskMover is a deliberately-injectable collaborator (passed to RenameExecutor/UndoReplayer and
# spied/exercised as an instance in tests). Marking Move/Rollback static would break that DI seam and
# every `_disk.Move(...)`/`mover.Move(...)` call site (CS0176) — a design change, not a lint fix.
# Keep them instance methods; CA1822 (mark static) is intentionally relaxed for this one file.
[extensions/Renamer/src/Renamer/Execution/DiskMover.cs]
dotnet_diagnostic.CA1822.severity = none

# Tests: relax a few rules that fight idiomatic xUnit.
[extensions/Renamer/src/Renamer.Tests/**.cs]
dotnet_diagnostic.CA1707.severity = none
dotnet_diagnostic.CA1822.severity = none
dotnet_diagnostic.CA2007.severity = none
# CA1861 (hoist constant array args to static readonly fields) is a micro-perf rule that fights
# inline literal arrays in test arrange/assert (e.g. Assert.Equal(new[] { 3, 2, 1 }, ...)); test
# readability wins over a non-measurable allocation in a unit test.
dotnet_diagnostic.CA1861.severity = none

# Same test-rule relaxations for the WhisparrSync test project.
[extensions/WhisparrSync/src/WhisparrSync.Tests/**.cs]
dotnet_diagnostic.CA1707.severity = none
dotnet_diagnostic.CA1822.severity = none
dotnet_diagnostic.CA2007.severity = none
dotnet_diagnostic.CA1861.severity = none
