{
  "config": {
    "default": true,
    "MD013": false, // line-length: prose wraps freely; code/tables overflow
    "MD033": false, // allow inline HTML (badges, <details>)
    "MD041": false, // first line need not be H1 (front-matter/badges)
    "MD024": { "siblings_only": true } // duplicate headings OK across sections
  },
  "globs": ["**/*.md"],
  // Lint only user-facing docs. .planning/** is internal research/spec; CLAUDE.md files are
  // AI-assistant instruction files (managed separately from product docs) — excluded from the
  // CI markdown-lint glob too.
  "ignores": ["**/node_modules/**", "**/dist/**", "**/.planning/**", "**/.archive/**", "**/CLAUDE.md", "**/e2e/fixtures/**"]
}
