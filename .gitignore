**/bin/*
**/obj/*
artifacts/
*.zip
.DS_Store
.playwright-mcp/
*.playwright-mcp.yml

# JS workspace installs — the root npm install (workspaces) hoists deps here; also covers any
# nested node_modules. Node/Playwright test artifacts are additionally ignored in tests/e2e/.gitignore.
node_modules/

# Local planning / AI-assistant scaffolding — not part of the published extension.
.planning/
# Durable local keepsakes (milestone screenshots, research snapshots) — never published.
.archive/
.claude/
.agents/
.cursor/
.codex/
CLAUDE.local.md

# Docusaurus build output — website/ is a standalone package (see website/package.json);
# node_modules/ is already covered by the existing root rule above.
website/build/
.whisparr-audit/

# Local manual-test scratch that must never be committed: screenshots dropped at the repo root,
# stray browser-snapshot dumps, and the runtime-populated E2E media dir (the E2E uses SkyHook JSON
# fixtures, not committed media). Docs images live under website/static/img and are unaffected.
/*.png
/*.jpg
/*.jpeg
/settings-whisparr.yml
tests/e2e/docker/shared-media/
